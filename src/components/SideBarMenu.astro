---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300"; // For primary color replace with `active` class
---

<ul class="menu grow shrink menu-md overflow-y-auto">
  <li class="mb-1">
    <a
      class:list={[
        "py-3 text-base",
        sideBarActiveItemID === "home" && activeClass,
      ]}
      aria-current={sideBarActiveItemID === "home" ? "page" : undefined}
      href="/"
    >
      Home
    </a>
  </li>
  <li class="mb-1">
    <a
      class:list={[
        "py-3 text-base",
        sideBarActiveItemID === "projects" && activeClass,
      ]}
      aria-current={sideBarActiveItemID === "projects" ? "page" : undefined}
      href="/projects"
    >
      Projects
    </a>
  </li>
  <li>
    <a
      class:list={[
        "py-3 text-base",
        sideBarActiveItemID === "cv" && activeClass,
      ]}
      aria-current={sideBarActiveItemID === "cv" ? "page" : undefined}
      href="/cv"
    >
      CV
    </a>
  </li>
</ul>
